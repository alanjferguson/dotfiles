[user]
# Allows me to configure email per repo instead of globally
  name = Alan Ferguson
  useConfigOnly = true

[init]
  defaultBranch = main
[color]
  status = auto
  branch = auto
  interactive = auto
  diff = auto
  ui = true
[push]
  recurseSubmodules = check
[pull]
  rebase = false
[rebase]
  autosquash = true
  updateRefs = true

# Force SSH for everything, might be too blunt an intrument
[url "git@github.com:"]
  insteadOf = https://github.com/

[url "git@gitlab.com:"]
  insteadOf = https://gitlab.com/

# Show three-way merge by default (i.e. mine, older, yours)
[merge]
  conflictStyle = zdiff3
